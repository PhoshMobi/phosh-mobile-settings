<?xml version="1.0" encoding="UTF-8"?>
<interface domain="phosh-mobile-settings">
  <template class="MsHiddenAppsDialog" parent="AdwDialog">
    <property name="title" translatable="yes">Hidden Apps</property>
    <property name="content-width">400</property>
    <property name="content-height">475</property>
    <property name="default-widget">select_button</property>
    <property name="child">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <property name="show-end-title-buttons">False</property>
            <child type="start">
              <object class="GtkButton">
                <property name="label" translatable="yes">_Cancel</property>
                <property name="use_underline">True</property>
                <property name="valign">center</property>
                <signal name="clicked" handler="adw_dialog_close" object="MsHiddenAppsDialog" swapped="yes"/>
              </object>
            </child>
            <child type="end">
              <object class="GtkButton" id="select_button">
                <property name="label" translatable="yes">_Select</property>
                <binding name="sensitive">
                  <closure type='gboolean' function='n_selected_to_sensitive'>
                    <lookup name="n-selected">MsHiddenAppsDialog</lookup>
                  </closure>
                </binding>
                <property name="use_underline">True</property>
                <property name="valign">center</property>
                <signal name="clicked" handler="on_select_button_clicked" object="MsHiddenAppsDialog" swapped="yes"/>
                <style>
                  <class name="suggested-action"/>
                </style>
              </object>
            </child>
          </object>
        </child>
        <property name="content">
          <object class="GtkScrolledWindow">
            <property name="hscrollbar-policy">never</property>
            <property name="vscrollbar-policy">automatic</property>
            <property name="propagate-natural-height">True</property>
            <property name="min-content-height">200</property>
            <property name="child">
              <object class="GtkStack" id="stack">
                <child>
                  <object class="GtkStackPage">
                    <property name="name">has-hidden</property>
                    <property name="child">
                      <object class="AdwPreferencesPage">
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title">Currently Hidden Applications</property>
                            <property name="description">Select the apps you want to make visible again</property>
                            <child>
                              <object class="GtkListBox" id="hidden_apps_listbox">
                                <property name="can-focus">True</property>
                                <property name="halign">fill</property>
                                <property name="valign">fill</property>
                                <property name="selection-mode">none</property>
                                <property name="show-separators">True</property>
                                <style>
                                  <class name="boxed-list"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="GtkStackPage">
                    <property name="name">no-hidden</property>
                    <property name="child">
                      <object class="AdwStatusPage">
                        <property name="margin-start">6</property>
                        <property name="margin-end">6</property>
                        <property name="vexpand">1</property>
                        <property name="icon-name">grid-large-symbolic</property>
                        <property name="title" translatable="yes">No Apps are Currently Hidden</property>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </property>
      </object>
    </property>
  </template>
</interface>
